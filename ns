<script>
function checkPassword() {
  const input = document.getElementById('pwInput');
  const error = document.getElementById('pwError');
  const val = input.value.trim();

  if (val === 'deathrocks031326') {
    const gate = document.getElementById('gate');
    gate.style.transition = 'opacity 0.6s ease';
    gate.style.opacity = '0';
    setTimeout(function() {
      gate.style.display = 'none';
      const content = document.getElementById('content');
      content.classList.add('visible');
      document.body.style.overflow = '';
    }, 600);
  } else {
    input.classList.add('error');
    error.textContent = 'Incorrect password. Please try again.';
    input.value = '';
    setTimeout(function() {
      input.classList.remove('error');
    }, 400);
  }
}

document.getElementById('pwInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') checkPassword();
  document.getElementById('pwError').textContent = ' ';
  this.classList.remove('error');
});

document.body.style.overflow = 'hidden';

// Comp plan JS

// Commission rates per tier — matches internal plan exactly
// Tiers 0-4: T1(1-9), T2(10-20), T3(21-35), T4(36-50), T5(51+)
const TIERS = [
  { label: 'Tier 1', range: '1 to 9',   human: 15, pet: 10, pnh: 10, pnp: 5,  color: '#B5AF9F' },
  { label: 'Tier 2', range: '10 to 20', human: 30, pet: 15, pnh: 15, pnp: 10, color: '#7A7464' },
  { label: 'Tier 3', range: '21 to 35', human: 45, pet: 30, pnh: 25, pnp: 15, color: '#5B7B6A' },
  { label: 'Tier 4', range: '36 to 50', human: 55, pet: 40, pnh: 30, pnp: 20, color: '#4A6A59' },
  { label: 'Tier 5', range: '51+',      human: 70, pet: 50, pnh: 40, pnp: 25, color: '#C8843A' },
];

// Target mix: 24H : 4P : 3PNH : 0PNP out of 31 total
const TOTAL_TARGET = 31;
const MIX_H   = 24 / TOTAL_TARGET;
const MIX_P   =  4 / TOTAL_TARGET;
const MIX_PNH =  3 / TOTAL_TARGET;

const PRICES = { h: 2495, p: 1195, pnh: 2495 };
const BASE   = 60000;

function getTierIdx(t) {
  if (t >= 51) return 4;
  if (t >= 36) return 3;
  if (t >= 21) return 2;
  if (t >= 10) return 1;
  return 0;
}

function fmt$(n)  { return '$' + Math.round(n).toLocaleString(); }
function fmtK(n)  { return n >= 1000 ? '$' + (n / 1000).toFixed(0) + 'K' : fmt$(n); }

function calc(total) {
  const ti = getTierIdx(total);
  const r  = TIERS[ti];
  const qH   = Math.round(total * MIX_H);
  const qP   = Math.round(total * MIX_P);
  const qPNH = Math.max(0, total - qH - qP);
  const commH   = qH   * r.human;
  const commP   = qP   * r.pet;
  const commPNH = qPNH * r.pnh;
  const comm    = commH + commP + commPNH;
  const rev     = qH * PRICES.h + qP * PRICES.p + qPNH * PRICES.pnh;
  const mo      = BASE / 12 + comm;
  return { ti, r, qH, qP, qPNH, comm, commH, commP, commPNH, rev, mo, annual: mo * 12 };
}

function getPhase(t) {
  if (t <= 22) return { cls: 'p1', label: 'Phase 1: Day one baseline' };
  if (t <= 40) return { cls: 'p2', label: 'Phase 2: Target volume' };
  return { cls: 'p3', label: 'Phase 3: Your own momentum' };
}

function set(id, val) { document.getElementById(id).textContent = val; }

function update(total) {
  const d  = calc(total);
  const ph = getPhase(total);
  const maxQ = Math.max(d.qH, 1);

  document.getElementById('sliderDisplay').innerHTML = total + ' <span>sales / mo</span>';
  set('resMo',     fmt$(d.mo));
  set('resMoSub',  fmt$(BASE / 12) + ' base + ' + fmt$(d.comm) + ' commission');
  set('resAnnual', fmt$(d.annual));
  set('resRev',    fmt$(d.rev));
  set('resRevSub', fmtK(d.rev * 12) + ' / yr');

  document.getElementById('barH').style.width   = (d.qH   / maxQ * 100) + '%';
  document.getElementById('barP').style.width   = (d.qP   / maxQ * 100) + '%';
  document.getElementById('barPNH').style.width = (d.qPNH / maxQ * 100) + '%';
  set('qtyH',   d.qH);   set('commH',   fmt$(d.commH));   set('revH',   fmtK(d.qH   * PRICES.h));
  set('qtyP',   d.qP);   set('commP',   fmt$(d.commP));   set('revP',   fmtK(d.qP   * PRICES.p));
  set('qtyPNH', d.qPNH); set('commPNH', fmt$(d.commPNH)); set('revPNH', fmtK(d.qPNH * PRICES.pnh));

  const pi = document.getElementById('phaseIndicator');
  const pd = document.getElementById('phaseDot');
  pi.className = 'phase-indicator ' + ph.cls;
  pd.className = 'phase-dot ' + ph.cls;
  set('phaseLabel', ph.label);
}

// Build tier table
(function () {
  const tbody = document.getElementById('tierBody');
  TIERS.forEach(function(t, i) {
    const isTarget = i === 2;
    const tag = isTarget ? '<span class="tag-target">TARGET</span>' : '';
    const even = i % 2 !== 0 ? 'background:var(--stone-50)' : '';
    tbody.innerHTML += '<tr' + (isTarget ? ' class="tier-target"' : '') + '>'
      + '<td>' + t.label + tag + '</td>'
      + '<td style="color:var(--stone-600);">' + t.range + '</td>'
      + '<td style="font-weight:600;color:' + t.color + ';">$' + t.human + '</td>'
      + '<td style="font-weight:600;color:' + t.color + ';">$' + t.pet   + '</td>'
      + '<td style="font-weight:600;color:' + t.color + ';">$' + t.pnh   + '</td>'
      + '<td style="font-weight:600;color:' + t.color + ';">$' + t.pnp   + '</td>'
      + '</tr>';
  });
})();

document.getElementById('salesSlider').addEventListener('input', function () {
  update(parseInt(this.value, 10));
});

update(31);

</script>
